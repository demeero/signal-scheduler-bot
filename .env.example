# Required for all run modes.
SIGNAL_ACCOUNT=+380501234567

# Local development defaults.
# docker-compose overrides SIGNAL_API_BASE_URL and BOLT_PATH for the scheduler service.
SIGNAL_API_BASE_URL=http://localhost:18080
TIMEZONE=Europe/Kyiv

# Logging.
LOG_CONFIG=true
LOG_LEVEL=debug
LOG_ADD_SOURCE=true
LOG_JSON=false
LOG_PRETTY=true

# Storage.
BOLT_PATH=./var/signal-scheduler-bot
BOLT_TIMEOUT=5s

# Signal API client.
SIGNAL_REQUEST_TIMEOUT=30s

# Polling and scheduling.
BOT_POLL_INTERVAL=5s
OUTBOX_WORKER_INTERVAL=1s
OUTBOX_VACUUM_INTERVAL=1h
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_MAX_AGE=15m
OUTBOX_VACUUM_RETENTION=720h
